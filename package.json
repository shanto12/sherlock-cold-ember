{
  "name": "sherlock-cold-ember",
  "version": "1.0.0",
  "description": "A cinematic, accessible Sherlock Holmes moving casebook set in London in 1895.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shanto12/sherlock-cold-ember.git"
  },
  "homepage": "https://sherlock-cold-ember.netlify.app",
  "bugs": {
    "url": "https://github.com/shanto12/sherlock-cold-ember/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "dev:next": "next dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:netlify": "next build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "start:next": "next start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "test:e2e": "playwright test",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build:netlify && npm run audit:prod"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.0",
    "@playwright/test": "1.55.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4",
    "wrangler": "4.111.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  },
  "type": "module"
}
